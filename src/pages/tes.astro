---
import Layout from "../layouts/Layout.astro";

import Navbar from "../components/Navbar.astro";

import Footer from "../components/Footer.astro";

const memory = {
  title: "My First School Performance",
  date: "2017",
  location: "Bogor, Indonesia",
  description:
    "One of the earliest videos I still have. Captured during a school performance and somehow survived all the old phones and hard drives.",
  likes: 12,
  comments: 4,
  tags: ["school", "childhood", "performance"],
};
---

<Layout>
  <body class="bg-[#E9E3D5] min-h-screen flex items-center justify-center p-8">

    <div
      class="w-full max-w-6xl bg-[#FFFDF8] border-2 border-black shadow-[10px_10px_0_rgba(0,0,0,1)] p-6 relative"
    >
      <!-- tape -->
      <div
        class="absolute -top-3 left-12 w-20 h-8 bg-yellow-200 border-2 border-black rotate-[-6deg] opacity-90"
      ></div>

      <div
        class="absolute -top-2 right-16 w-20 h-8 bg-blue-200 border-2 border-black rotate-[8deg] opacity-90"
      ></div>

      <div class="grid lg:grid-cols-[420px_80px_1fr] gap-8">

        <!-- VIDEO -->
        <div class="flex justify-center">
          <div
            class="bg-black border-4 border-black shadow-[8px_8px_0_rgba(0,0,0,1)] p-2"
          >
            <video
              controls
              poster="https://picsum.photos/600/1000"
              class="aspect-[9/16] w-[320px] object-cover"
            >
            </video>
          </div>
        </div>

        <!-- ACTIONS -->
        <div class="flex lg:flex-col gap-4 justify-center">

          <button
            class="bg-white border-2 border-black w-16 h-16 shadow-[4px_4px_0_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all"
          >
            ❤️
            <div class="text-xs font-black">
              {memory.likes}
            </div>
          </button>

          <button
            class="bg-white border-2 border-black w-16 h-16 shadow-[4px_4px_0_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all"
          >
            💬
            <div class="text-xs font-black">
              {memory.comments}
            </div>
          </button>

          <button
            class="bg-white border-2 border-black w-16 h-16 shadow-[4px_4px_0_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all"
          >
            ↗️
          </button>

        </div>

        <!-- CONTENT -->
        <div>

          <div class="flex flex-wrap gap-2 mb-4">
            {memory.tags.map((tag) => (
              <span
                class="px-2 py-1 border border-black bg-[#BFD9FF] font-black uppercase text-[10px]"
              >
                {tag}
              </span>
            ))}
          </div>

          <h1 class="text-4xl font-black mb-2">
            {memory.title}
          </h1>

          <p
            class="text-xs font-bold uppercase tracking-wider text-neutral-500 border-b-2 border-black pb-3 mb-5"
          >
            {memory.date} — {memory.location}
          </p>

          <p class="leading-relaxed text-neutral-700 max-w-prose">
            {memory.description}
          </p>

          <div
            class="mt-8 border-2 border-black bg-[#F3EFE6] p-4 shadow-[4px_4px_0_rgba(0,0,0,1)]"
          >
            <div class="font-black uppercase text-xs mb-2">
              People in Frame
            </div>

            <div class="flex flex-wrap gap-2">
              <span
                class="px-2 py-1 border-2 border-black bg-black text-white text-xs font-bold"
              >
                Pasha
              </span>

              <span
                class="px-2 py-1 border-2 border-black bg-white text-black text-xs font-bold"
              >
                Fajar
              </span>
            </div>
          </div>

        </div>

      </div>

    </div>

  </body>
</Layout>